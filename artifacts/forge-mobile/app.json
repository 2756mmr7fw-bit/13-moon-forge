{
  "expo": {
    "name": "13 Moon Forge",
    "slug": "forge-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "forge-mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Companion app for the 13 Moon Forge ecosystem. Check your projects, get a Fix from Flint, browse the Town Square, and manage your account on the go. Subscriptions and purchases are managed on the web at 13moonforge.ai.",
    "primaryColor": "#F97316",
    "privacy": "public",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.thirteenmoonforge.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.developer-tools",
        "NSUserTrackingUsageDescription": "We do not track you across apps. This permission is required by iOS even when no tracking occurs."
      },
      "associatedDomains": [
        "applinks:13moonforge.ai",
        "applinks:thepeoplestownsquare.ai"
      ]
    },
    "android": {
      "package": "ai.thirteenmoonforge.app",
      "versionCode": 1,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#111111"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://13moonforge.ai/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      },
      "privacyPolicyUrl": "https://13moonforge.ai/privacy",
      "termsOfServiceUrl": "https://13moonforge.ai/terms",
      "supportUrl": "https://13moonforge.ai/support"
    }
  }
}
