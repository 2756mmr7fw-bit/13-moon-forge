# ─── Database ────────────────────────────────────────────────────────────────
# When running with docker-compose, use the internal service name:
DATABASE_URL_PROD=postgresql://forge:changeme@db:5432/forge

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=https://13moonforge.ai

# ─── Session ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=

# ─── Auth (Replit OIDC) ───────────────────────────────────────────────────────
# Your Replit project's REPL_ID — found in the Replit workspace URL or
# via: curl https://replit.com/oidc/.well-known/openid-configuration
# This is the OIDC client_id used for login. Replit OIDC works from any host.
OIDC_CLIENT_ID=
# ISSUER_URL defaults to https://replit.com/oidc — only override for custom OIDC
# ISSUER_URL=https://replit.com/oidc

# ─── AI / Moon API ───────────────────────────────────────────────────────────
MOON_API_KEY=
TPTS_MOON_API_KEY=
TSQ_MOON_API_KEY=
TPTS_INBOUND_KEY=

# ─── Third-party services ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
RESEND_API_KEY=
SQUARE_API_KEY=

# ─── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated Replit user IDs or emails for admin access
ADMIN_USER_IDS=
ADMIN_EMAILS=

# ─── Docker image (docker-compose) ───────────────────────────────────────────
# Override the image tag to deploy a specific version:
# FORGE_IMAGE=sovereigndigital/forge:v1.2.3
FORGE_IMAGE=13moonstpts/forge:latest

# ─── Postgres (docker-compose) ───────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
